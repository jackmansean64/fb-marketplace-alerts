# Mailgun credentials — fill these in after creating your Mailgun account.
# 1. Sign up at https://www.mailgun.com/ and verify a sending domain.
# 2. Copy this file to `.env` and replace the placeholder values below.

# Your Mailgun private API key (Settings → API Keys).
MAILGUN_API_KEY="REPLACE_WITH_YOUR_MAILGUN_API_KEY"

# The sending domain you configured in Mailgun (e.g. mg.yourdomain.com).
MAILGUN_DOMAIN="REPLACE_WITH_YOUR_MAILGUN_DOMAIN"

# The "From" address alerts will be sent from. Must be on your Mailgun domain.
# Format can be a plain address or "Display Name <address@domain>".
MAILGUN_FROM_ADDRESS="Marketplace Alerts <alerts@REPLACE_WITH_YOUR_MAILGUN_DOMAIN>"

# Optional: set to "false" to disable email sending (useful for local testing).
# EMAIL_NOTIFICATIONS_ENABLED="true"
